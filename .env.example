# 环境变量配置说明
# 复制本文件为 .env.local 并填入实际值

# 管理员用户名
VITE_ADMIN_USERNAME=admin

# 管理员密码的 SHA-256 哈希值（不要填写明文密码！）
# 生成方法: echo -n "yourpassword" | shasum -a 256 | cut -d ' ' -f 1
# 或使用 Node.js: node -e "const c=require('crypto');console.log(c.createHash('sha256').update('yourpassword').digest('hex'))"
VITE_ADMIN_PWD_HASH=

# Session 签名密钥（用于防止 sessionStorage 篡改）
# 生成方法: openssl rand -hex 32
# 或使用 Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_SESSION_SECRET=
